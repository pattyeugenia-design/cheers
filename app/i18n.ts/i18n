// app/i18n.ts
// Sistema de traducciones compartido para toda la app
// Detecta el idioma del browser y lo guarda en localStorage

export type Lang = 'es' | 'en'

export function getLang(): Lang {
  if (typeof window === 'undefined') return 'es'
  const saved = localStorage.getItem('cheers_lang')
  if (saved === 'es' || saved === 'en') return saved
  const browser = navigator.language?.toLowerCase() || 'es'
  const lang: Lang = browser.startsWith('en') ? 'en' : 'es'
  localStorage.setItem('cheers_lang', lang)
  return lang
}

export function setLang(lang: Lang) {
  if (typeof window !== 'undefined') {
    localStorage.setItem('cheers_lang', lang)
  }
}

